{
  "name": "function-thumb",
  "description": "Cloud Functions for Firebase - thumbnail generation",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "build": "tsc",
    "deploy": "npm run build && firebase deploy --only functions:generateThumbnail",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^7.0.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "eslint": "^9.35.0",
    "eslint-config-google": "^0.14.0",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.8.0"
  },
  "private": true
}
